#!/usr/bin/env bash

#	ArchMaintainer 1.4
#	Preforms maintenance and removes excess stuff from Arch.
#	Dependencies: pacman, git, rankmirrors-systemd
#
#	By Joris van Dijk | Jorisvandijk.com
#	Licensed under the GNU General Public License v3.0

GRN='\033[0;32m'
NC='\033[0m'

PKGLISTLOCATION=$HOME/.config

# Check for failed systemd services
printf "\n${GRN}>> Checking failed services:${NC}\n"
systemctl --failed | grep -v "masked"

# Remove orphaned packages
printf "\n${GRN}>> Removing orphaned packages if any.${NC}\n"
sudo pacman -Rs $(pacman -Qqtd)
printf "If 'no targets specified', no orphaned packages were found.\n"

# Delete Pacman cache
printf "\n${GRN}>> Deleting Pacman cache.${NC}"
printf "\nCurrent size: "
du -sh /var/cache/pacman/pkg/ 2>/dev/null || echo "Cache directory not found"
sudo pacman -Sc --noconfirm 2>/dev/null
printf "\nNew size: "
du -sh /var/cache/pacman/pkg/ 2>/dev/null || echo "Cache directory not found"

# Empty ~/.cache
printf "\n${GRN}>> Emptying ~/.cache.${NC}"
if [ -d "$HOME/.cache" ]; then
  printf "\nCurrent size: "
  du -sh $HOME/.cache
  rm -rf $HOME/.cache/*
  printf "\nNew size: "
  du -sh $HOME/.cache
else
  printf "\n~/.cache directory not found\n"
fi

# Empty Trash
printf "\n${GRN}>> Emptying Trash.${NC}\n"
if command -v trash-empty &> /dev/null; then
  trash-empty
  printf "Trash emptied successfully\n"
else
  printf "trash-empty command not found\n"
fi

# Saving a list of installed packages
printf "\n${GRN}>> Saving list of installed packages.${NC}\n"
pacman -Qqe > $PKGLISTLOCATION/pkglist

# Updating and ranking mirrors
if [[ $(sudo pacman -Q | grep pacman-contrib | wc -l) -ge 1 ]]; then
  printf "\n${GRN}>> Updating and ranking mirrors in mirrorlist.${NC}\n"
  sudo cp /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.backup
  cd $HOME
  curl -s "https://archlinux.org/mirrorlist/?country=AR&protocol=https&use_mirror_status=on" | sed -e 's/^#Server/Server/' -e '/^#/d' | rankmirrors -n 10 - > mirrorlist
  sudo mv mirrorlist /etc/pacman.d/mirrorlist
fi

# Done
printf "\n${GRN}>> Done!${NC}\n"
